{
  "name": "swarm-judge",
  "description": "Dispatch independent hands, then synthesize their result artifacts with one judge rig.",
  "parameters": {
    "hands": "Expanded dispatch children",
    "judge_task": "Synthesis instruction",
    "judge_rig": "Registered judge rig name"
  },
  "expression": {
    "kind": "combine",
    "inputs": "${hands}",
    "task": "${judge_task}",
    "rig": {"name": "${judge_rig}"}
  }
}
